# Skyfusion Analytics - Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Frontend
REACT_APP_API_URL=http://localhost:3001/api/v1
REACT_APP_SOCKET_URL=http://localhost:3001
REACT_APP_MAPBOX_TOKEN=your_mapbox_token_here

# Neo4j
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# Google Earth Engine
GOOGLE_EARTH_ENGINE_SERVICE_ACCOUNT=your_service_account.json
GOOGLE_EARTH_ENGINE_PRIVATE_KEY=your_private_key

# TensorFlow Model
TF_MODEL_PATH=./data/models
TF_MODEL_NAME=skyfusion_model

# Logging
LOG_LEVEL=info

# Security
JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=http://localhost:3000
