# Preprocessor - Variables de Entorno
# Copiar a .env y configurar valores

# Google Earth Engine
GEE_PROJECT_ID=skyfusion-analytics
GEE_SERVICE_ACCOUNT_KEY=./config/gee-service-account.json

# Event Bus Configuration
# Opciones: 'rabbitmq' o 'redis'
EVENT_BUS_TYPE=rabbitmq

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Redis
REDIS_URL=redis://localhost:6379/0

# Exchange y Routing
EVENT_EXCHANGE=geo_events
EVENT_ROUTING_KEY=imagenes.historicas.listas

# Parámetros de Filtrado
CLOUD_COVER_THRESHOLD=15

# Descarga Cruda (opcional)
# 'true' para descargar también archivos GeoTIFF a Google Drive
# Los archivos se registran en data/raw/satelite/metadata/catalog.csv
DOWNLOAD_RAW=false
DRIVE_FOLDER=Skyfusion_Combeima

# Paths
OUTPUT_DATA_PATH=./data/output
